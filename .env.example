# Placeholders only. NEVER commit real values.
# Copy to .env for local dev, or place secrets in /etc/luigi-web.env on the LXC.
LUIGI_WEB_PG_HOST=10.0.0.202
LUIGI_WEB_PG_PORT=5432
LUIGI_WEB_PG_DB=luigi_todo
LUIGI_WEB_PG_USER=luigi_web
LUIGI_WEB_PG_PASSWORD=changeme
LUIGI_WEB_UI_TOKEN=changeme
LUIGI_WEB_BIND=0.0.0.0
LUIGI_WEB_PORT=8080

# Path to the env file the Admin > "Environment file" editor writes.
# Leave unset for local dev (defaults to <repo>/.env).
# On the LXC set: LUIGI_WEB_ENV_FILE=/etc/luigi-web.env
# LUIGI_WEB_ENV_FILE=

# --- LLM chat (Home dashboard "Assistant" panel) ---
# Any OpenAI-compatible /chat/completions endpoint works. Leave API_KEY blank
# to disable the panel entirely.
#
# Default targets GitHub Models (uses a GitHub PAT with models:read scope):
#   https://github.com/settings/tokens  → fine-grained token → Models: Read
LUIGI_WEB_LLM_PROVIDER=openai
LUIGI_WEB_LLM_BASE_URL=https://models.github.ai/inference
LUIGI_WEB_LLM_API_KEY=
LUIGI_WEB_LLM_MODEL=openai/gpt-4o-mini
LUIGI_WEB_LLM_TIMEOUT=60
LUIGI_WEB_LLM_MAX_TOOL_ITERATIONS=5

# --- Game'N'Watch (Games/Shows tabs) ---
# Reads/writes the SAME Google Sheet the Game'N'Watch Discord bot uses:
#   https://github.com/Preston-Robertson/Game-N-Watch
#
# Setup:
#   1. Reuse the bot's Google service account (it already has Editor access to
#      the sheet). Copy its credentials.json onto this host, e.g.
#        /etc/luigi-web-gnw.json   (chmod 640, owner root:luigi-web)
#   2. Put the Sheet ID here (the long id in the sheet URL:
#        https://docs.google.com/spreadsheets/d/<THIS_PART>/edit )
#   3. The service-account email must have Editor access to that sheet
#      (it already does if it's the bot's account).
#
# Leave LUIGI_WEB_GNW_SHEET_ID blank to hide the Games/Shows tabs entirely.
LUIGI_WEB_GNW_SHEET_ID=
# Leave LUIGI_WEB_GNW_CREDS_FILE BLANK to use the app-managed path
# (<repo>/gnw-credentials.json) that the Admin page can write to directly —
# recommended, since it needs no host-side file placement. Only set this if
# you want the key at a specific path the service can write to.
LUIGI_WEB_GNW_CREDS_FILE=
